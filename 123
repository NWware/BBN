local RunService = game:GetService("RunService")
local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local Camera = workspace.CurrentCamera
local LocalPlayer = Players.LocalPlayer

local ESPObjects = {}
local Highlights = {}
local Connections = {}

local infiniteSprint = false
local sprintConn = nil
local isMobile = UserInputService.TouchEnabled and not UserInputService.KeyboardEnabled

local function DisconnectAll()
    for key, conn in pairs(Connections) do
        if typeof(conn) == "RBXScriptConnection" then
            conn:Disconnect()
        end
        Connections[key] = nil
    end
end

local function ClearAllHighlights()
    for instance, hl in pairs(Highlights) do
        pcall(function()
            hl:Destroy()
        end)
        Highlights[instance] = nil
    end
end

local function ClearAllESP()
    for key, obj in pairs(ESPObjects) do
        pcall(function()
            obj.Visible = false
            obj:Remove()
        end)
        ESPObjects[key] = nil
    end
end

local function ClearEverything()
    ClearAllHighlights()
    ClearAllESP()
end

local function WorldToScreen(position)
    local screenPos, onScreen = Camera:WorldToViewportPoint(position)
    return Vector2.new(screenPos.X, screenPos.Y), onScreen, screenPos.Z
end

local function AddHighlight(instance, color)
    if not instance or not instance.Parent then return end
    local existing = Highlights[instance]
    if existing then
        if existing.Parent then
            if existing.FillColor ~= color then
                existing.FillColor = color
                existing.OutlineColor = color
            end
            return
        else
            Highlights[instance] = nil
        end
    end
    local hl = Instance.new("Highlight")
    hl.Adornee = instance
    hl.FillColor = color
    hl.OutlineColor = color
    hl.FillTransparency = 0.85
    hl.OutlineTransparency = 0.3
    hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    hl.Parent = game:GetService("CoreGui")
    Highlights[instance] = hl
end

local function RemoveHighlight(instance)
    if Highlights[instance] then
        pcall(function()
            Highlights[instance]:Destroy()
        end)
        Highlights[instance] = nil
    end
end

local function RemoveHighlightRecursive(instance)
    RemoveHighlight(instance)
    if instance:IsA("Model") or instance:IsA("Folder") then
        for _, desc in ipairs(instance:GetDescendants()) do
            RemoveHighlight(desc)
        end
    end
end

local function CreateESPText()
    local text = Drawing.new("Text")
    text.Visible = false
    text.Center = true
    text.Outline = true
    text.Font = 2
    text.Size = 16
    return text
end

local function GetRootPart(model)
    return model:FindFirstChild("HumanoidRootPart")
        or model:FindFirstChild("Head")
        or model:FindFirstChildWhichIsA("BasePart")
end

local function CleanESPByPattern(pattern)
    for key, obj in pairs(ESPObjects) do
        if string.find(key, pattern) then
            pcall(function()
                obj.Visible = false
                obj:Remove()
            end)
            ESPObjects[key] = nil
        end
    end
end

local function FindMyCharacter()
    local playersFolder = workspace:FindFirstChild("PLAYERS")
    if not playersFolder then return nil end
    local aliveFolder = playersFolder:FindFirstChild("ALIVE")
    if aliveFolder then
        local char = aliveFolder:FindFirstChild(LocalPlayer.Name)
        if char then return char end
    end
    local killerFolder = playersFolder:FindFirstChild("KILLER")
    if killerFolder then
        local char = killerFolder:FindFirstChild(LocalPlayer.Name)
        if char then return char end
    end
    return nil
end

RunService.Heartbeat:Connect(function()
    pcall(function()
        local char = FindMyCharacter()
        if char then
            char:SetAttribute("Stamina", 9999999)
            char:SetAttribute("MaxStamina", 9999999)
        end
    end)
end)


local function WatchFolder(folder, prefix)
    if not folder then return end
    local connKey = prefix .. "_" .. folder.Name .. "_removed"
    if Connections[connKey] then
        Connections[connKey]:Disconnect()
    end

    Connections[connKey] = folder.ChildRemoved:Connect(function(child)
        RemoveHighlightRecursive(child)
        for key, obj in pairs(ESPObjects) do
            if string.find(key, child.Name) then
                pcall(function()
                    obj.Visible = false
                    obj:Remove()
                end)
                ESPObjects[key] = nil
            end
        end
    end)

    local addKey = prefix .. "_" .. folder.Name .. "_added"
    if Connections[addKey] then
        Connections[addKey]:Disconnect()
    end

    Connections[addKey] = folder.ChildAdded:Connect(function(child)
    end)
end

local function WatchGameMap(gameMap)
    if not gameMap then return end

    local function setupDoors()
        local doorsFolder = gameMap:FindFirstChild("Doors")
        if doorsFolder then
            WatchFolder(doorsFolder, "doors")
        end
    end

    local function setupDoubleDoors()
        local doubleDoors = gameMap:FindFirstChild("Double Doors")
        if doubleDoors then
            WatchFolder(doubleDoors, "doubledoors")
        end
    end

    local function setupEscapes()
        local escapesFolder = gameMap:FindFirstChild("Escapes")
        if escapesFolder then
            WatchFolder(escapesFolder, "escapes")
        end
    end

    local function setupGenerators()
        local gensFolder = gameMap:FindFirstChild("Generators")
        if gensFolder then
            WatchFolder(gensFolder, "generators")
        end
    end

    setupDoors()
    setupDoubleDoors()
    setupEscapes()
    setupGenerators()

    local mapChildConn = "gamemap_childadded"
    if Connections[mapChildConn] then
        Connections[mapChildConn]:Disconnect()
    end
    Connections[mapChildConn] = gameMap.ChildAdded:Connect(function(child)
        task.wait(0.1)
        if child.Name == "Doors" then setupDoors()
        elseif child.Name == "Double Doors" then setupDoubleDoors()
        elseif child.Name == "Escapes" then setupEscapes()
        elseif child.Name == "Generators" then setupGenerators()
        end
    end)

    local mapRemovedConn = "gamemap_removed"
    if Connections[mapRemovedConn] then
        Connections[mapRemovedConn]:Disconnect()
    end
    Connections[mapRemovedConn] = gameMap.AncestryChanged:Connect(function(_, parent)
        if not parent then
            ClearEverything()
        end
    end)
end

-- === ИНИЦИАЛИЗАЦИЯ ОТСЛЕЖИВАНИЯ ===

local function InitWatchers()
    task.spawn(function()
        local pf = workspace:WaitForChild("PLAYERS", 30)
        if not pf then return end

        local function watchAliveKiller()
            local alive = pf:FindFirstChild("ALIVE")
            local killer = pf:FindFirstChild("KILLER")
            WatchFolder(alive, "alive")
            WatchFolder(killer, "killer")
        end

        watchAliveKiller()

        local pfConn = "pf_childadded"
        if Connections[pfConn] then Connections[pfConn]:Disconnect() end
        Connections[pfConn] = pf.ChildAdded:Connect(function(child)
            task.wait(0.1)
            if child.Name == "ALIVE" or child.Name == "KILLER" then
                WatchFolder(child, child.Name:lower())
            end
        end)

        local function watchFolderRemoval(folderName, prefix)
            local folder = pf:FindFirstChild(folderName)
            if folder then
                local key = prefix .. "_folder_destroyed"
                if Connections[key] then Connections[key]:Disconnect() end
                Connections[key] = folder.AncestryChanged:Connect(function(_, parent)
                    if not parent then
                        CleanESPByPattern(prefix)
                    end
                end)
            end
        end

        watchFolderRemoval("ALIVE", "alive")
        watchFolderRemoval("KILLER", "killer")

        pf.ChildAdded:Connect(function(child)
            task.wait(0.1)
            if child.Name == "ALIVE" then
                watchFolderRemoval("ALIVE", "alive")
            elseif child.Name == "KILLER" then
                watchFolderRemoval("KILLER", "killer")
            end
        end)
    end)

    task.spawn(function()
        local mapsFolder = workspace:WaitForChild("MAPS", 30)
        if not mapsFolder then return end

        local function tryWatchGameMap()
            local gm = mapsFolder:FindFirstChild("GAME MAP")
            if gm then
                WatchGameMap(gm)
            end
        end

        tryWatchGameMap()

        local mapsConn = "maps_childadded"
        if Connections[mapsConn] then Connections[mapsConn]:Disconnect() end
        Connections[mapsConn] = mapsFolder.ChildAdded:Connect(function(child)
            task.wait(0.5)
            if child.Name == "GAME MAP" then
                ClearEverything()
                WatchGameMap(child)
            end
        end)

        local mapsRemConn = "maps_childremoved"
        if Connections[mapsRemConn] then Connections[mapsRemConn]:Disconnect() end
        Connections[mapsRemConn] = mapsFolder.ChildRemoved:Connect(function(child)
            if child.Name == "GAME MAP" then
                ClearEverything()
            end
        end)
    end)
end

InitWatchers()

RunService.RenderStepped:Connect(function()
    for _, obj in pairs(ESPObjects) do
        obj.Visible = false
    end

    local playersFolder = workspace:FindFirstChild("PLAYERS")
    local aliveFolder = playersFolder and playersFolder:FindFirstChild("ALIVE")
    if aliveFolder then
        for _, model in ipairs(aliveFolder:GetChildren()) do
            if model:IsA("Model") and model.Name ~= LocalPlayer.Name then
                AddHighlight(model, Color3.fromRGB(0, 255, 0))
                local root = GetRootPart(model)
                if root then
                    local posTop, onScreenTop, depthTop = WorldToScreen(root.Position + Vector3.new(0, 3.5, 0))
                    local posBot, onScreenBot, depthBot = WorldToScreen(root.Position + Vector3.new(0, -3, 0))

                    local keyName = "alive_name_" .. model.Name
                    if not ESPObjects[keyName] then
                        ESPObjects[keyName] = CreateESPText()
                    end
                    if onScreenTop and depthTop > 0 then
                        ESPObjects[keyName].Position = posTop
                        ESPObjects[keyName].Text = model.Name
                        ESPObjects[keyName].Color = Color3.fromRGB(255, 255, 255)
                        ESPObjects[keyName].Visible = true
                    end

                    local keyHP = "alive_hp_" .. model.Name
                    if not ESPObjects[keyHP] then
                        ESPObjects[keyHP] = CreateESPText()
                        ESPObjects[keyHP].Size = 14
                    end
                    if onScreenBot and depthBot > 0 then
                        local hp = "?"
                        local maxhp = "?"
                        local hum = model:FindFirstChildOfClass("Humanoid")
                        if hum then
                            hp = math.floor(hum.Health)
                            maxhp = math.floor(hum.MaxHealth)
                        end
                        ESPObjects[keyHP].Position = posBot
                        ESPObjects[keyHP].Text = tostring(hp) .. " / " .. tostring(maxhp)
                        ESPObjects[keyHP].Color = Color3.fromRGB(255, 255, 255)
                        ESPObjects[keyHP].Visible = true
                    end
                end
            end
        end
    end

    local killerFolder = playersFolder and playersFolder:FindFirstChild("KILLER")
    if killerFolder then
        for _, model in ipairs(killerFolder:GetChildren()) do
            if model:IsA("Model") and model.Name ~= LocalPlayer.Name then
                AddHighlight(model, Color3.fromRGB(255, 0, 0))
                local root = GetRootPart(model)
                if root then
                    local posTop, onScreenTop, depthTop = WorldToScreen(root.Position + Vector3.new(0, 3.5, 0))
                    local posBot, onScreenBot, depthBot = WorldToScreen(root.Position + Vector3.new(0, -3, 0))

                    local keyName = "killer_name_" .. model.Name
                    if not ESPObjects[keyName] then
                        ESPObjects[keyName] = CreateESPText()
                    end
                    if onScreenTop and depthTop > 0 then
                        ESPObjects[keyName].Position = posTop
                        ESPObjects[keyName].Text = "[KILLER] " .. model.Name
                        ESPObjects[keyName].Color = Color3.fromRGB(255, 60, 60)
                        ESPObjects[keyName].Visible = true
                    end

                    local keyHP = "killer_hp_" .. model.Name
                    if not ESPObjects[keyHP] then
                        ESPObjects[keyHP] = CreateESPText()
                        ESPObjects[keyHP].Size = 14
                    end
                    if onScreenBot and depthBot > 0 then
                        local hp = "?"
                        local maxhp = "?"
                        local hum = model:FindFirstChildOfClass("Humanoid")
                        if hum then
                            hp = math.floor(hum.Health)
                            maxhp = math.floor(hum.MaxHealth)
                        end
                        ESPObjects[keyHP].Position = posBot
                        ESPObjects[keyHP].Text = tostring(hp) .. " / " .. tostring(maxhp)
                        ESPObjects[keyHP].Color = Color3.fromRGB(255, 255, 255)
                        ESPObjects[keyHP].Visible = true
                    end
                end
            end
        end
    end

    local mapsFolder = workspace:FindFirstChild("MAPS")
    local gameMap = mapsFolder and mapsFolder:FindFirstChild("GAME MAP")

    local doorsFolder = gameMap and gameMap:FindFirstChild("Doors")
    if doorsFolder then
        for _, obj in ipairs(doorsFolder:GetDescendants()) do
            if obj:IsA("Model") or obj:IsA("BasePart") then
                AddHighlight(obj, Color3.fromRGB(255, 255, 255))
            end
        end
    end

    local doubleDoors = gameMap and gameMap:FindFirstChild("Double Doors")
    if doubleDoors then
        for _, obj in ipairs(doubleDoors:GetDescendants()) do
            if obj:IsA("Model") or obj:IsA("BasePart") then
                AddHighlight(obj, Color3.fromRGB(255, 255, 255))
            end
        end
    end

    local escapesFolder = gameMap and gameMap:FindFirstChild("Escapes")
    if escapesFolder then
        for _, obj in ipairs(escapesFolder:GetDescendants()) do
            if obj:IsA("BasePart") or obj:IsA("Model") then
                AddHighlight(obj, Color3.fromRGB(255, 0, 0))
            end
        end
    end

    local gensFolder = gameMap and gameMap:FindFirstChild("Generators")
    if gensFolder then
        for i, gen in ipairs(gensFolder:GetChildren()) do
            if gen:IsA("Model") then
                AddHighlight(gen, Color3.fromRGB(170, 0, 255))
                local part = GetRootPart(gen)
                if part then
                    local pos, onScreen, depth = WorldToScreen(part.Position + Vector3.new(0, 5, 0))
                    local key = "gen_" .. tostring(i)
                    if not ESPObjects[key] then
                        ESPObjects[key] = CreateESPText()
                    end
                    if onScreen and depth > 0 then
                        local progress = gen:GetAttribute("Progress") or 0
                        ESPObjects[key].Position = pos
                        ESPObjects[key].Text = "Generator " .. tostring(math.floor(progress)) .. "%"
                        ESPObjects[key].Color = Color3.fromRGB(170, 0, 255)
                        ESPObjects[key].Visible = true
                    end
                end
            end
        end
    end
end)

-- === INFINITE SPRINT ===

maintab:Toggle("Infinite Sprint", "Allows You To Sprint Forever.", function(state)
    infiniteSprint = state

    if state then
        if sprintConn then sprintConn:Disconnect() end
        sprintConn = RunService.Heartbeat:Connect(function()
            if not infiniteSprint then return end
            pcall(function()
                local char = FindMyCharacter()
                if not char then return end

                if isMobile then
                    local hum = char:FindFirstChildOfClass("Humanoid")
                    if hum and hum.MoveDirection.Magnitude > 0 then
                        char:SetAttribute("WalkSpeed", 25)
                    else
                        char:SetAttribute("WalkSpeed", 12)
                    end
                else
                    if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) or UserInputService:IsKeyDown(Enum.KeyCode.RightShift) then
                        char:SetAttribute("WalkSpeed", 25)
                    else
                        char:SetAttribute("WalkSpeed", 12)
                    end
                end
            end)
        end)
    else
        if sprintConn then
            sprintConn:Disconnect()
            sprintConn = nil
        end
        pcall(function()
            local char = FindMyCharacter()
            if char then
                char:SetAttribute("WalkSpeed", 12)
            end
        end)
    end
end)
